generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum EventStatus {
  OPEN
  CLOSED
  RESOLVED
}

enum BetStatus {
  PENDING
  WON
  LOST
}

enum TransactionType {
  ADMIN_ADJUSTMENT
  ADMIN_GIFT
  BET_PLACED
  BET_SOLD
  BET_WON
  EVENT_CREATED
  EVENT_LIQUIDITY_RETURN
  INITIAL_GRANT
  /** Self-service premium subscription (one-time debit). */
  PREMIUM_PURCHASE
}

enum NotificationType {
  EVENT_RESOLVED_WON
  EVENT_RESOLVED_LOST
  DIRECT_MESSAGE
  ADMIN_COMPLAINT_NEW
}

/** What triggered a market price snapshot. */
enum SnapshotReason {
  INITIAL
  BUY
  SELL
  RESOLVE
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  /** When true, user sees extra per-event market insights (positions by outcome). */
  isPremium    Boolean  @default(false)
  balance      Int      @default(0)
  createdAt    DateTime @default(now())

  bets             Bet[]
  transactions     CoinTransaction[]
  createdEvents    Event[]            @relation("EventCreator")
  usedInviteCode   InviteCode?        @relation("UsedCode")
  createdCodes     InviteCode[]       @relation("CreatedCodes")
  complaintsFiled  Complaint[]        @relation("ComplaintSubmitter")
  notifications    Notification[]
  messagesSent     DirectMessage[]    @relation("MessagesSent")
  messagesReceived DirectMessage[]    @relation("MessagesReceived")
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdAt   DateTime  @default(now())
  usedAt      DateTime?

  createdBy   User      @relation("CreatedCodes", fields: [createdById], references: [id])
  createdById String

  usedBy      User?     @relation("UsedCode", fields: [usedById], references: [id])
  usedById    String?   @unique
}

model Event {
  id                String      @id @default(cuid())
  /** Monotonic public id; used in /events/[eventNumber] URLs. */
  eventNumber       Int         @unique @default(autoincrement())
  title             String
  description       String
  category          String
  closesAt          DateTime
  status            EventStatus @default(OPEN)
  createdAt         DateTime    @default(now())

  /** Creator-locked collateral (m). */
  liquidityM        Int         @default(100)
  /** LMSR depth parameter (b). */
  bParameter        Int         @default(100)
  /** House pool balance (collateral + net trade flows). */
  poolBalance       Int         @default(0)

  resolvedOutcome   Outcome?    @relation("ResolvedOutcome", fields: [resolvedOutcomeId], references: [id])
  resolvedOutcomeId String?

  createdBy         User        @relation("EventCreator", fields: [createdById], references: [id])
  createdById       String

  outcomes          Outcome[]   @relation("EventOutcomes")
  bets              Bet[]
  complaints        Complaint[]
  notifications     Notification[]
  priceSnapshots    MarketSnapshot[]
}

model Outcome {
  id             String  @id @default(cuid())
  label          String
  /** LMSR outstanding share quantity qᵢ for this outcome. */
  lmsrQ          Int     @default(0)

  event          Event   @relation("EventOutcomes", fields: [eventId], references: [id])
  eventId        String

  bets           Bet[]
  resolvedEvents Event[] @relation("ResolvedOutcome")
  snapshotPoints MarketSnapshotPoint[]
}

model Bet {
  id              String    @id @default(cuid())
  amount          Int
  shares          Int
  sharesRemaining Int
  priceAtBet      Int
  status          BetStatus @default(PENDING)
  payout          Int?
  createdAt       DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
  userId    String

  event     Event     @relation(fields: [eventId], references: [id])
  eventId   String

  outcome   Outcome   @relation(fields: [outcomeId], references: [id])
  outcomeId String
}

model CoinTransaction {
  id          String          @id @default(cuid())
  amount      Int
  type        TransactionType
  note        String?
  referenceId String?
  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id])
  userId      String
}

/** User-submitted complaint / report (moderation). */
model Complaint {
  id                 String   @id @default(cuid())
  body               String
  reportedUsername   String?
  createdAt          DateTime @default(now())

  event     Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventId   String?

  submitter   User?   @relation("ComplaintSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  submitterId String?

  notifications Notification[]
}

/** Private message between users (or admin → user). */
model DirectMessage {
  id         String    @id @default(cuid())
  body       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  fromUser   User @relation("MessagesSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  fromUserId String
  toUser     User @relation("MessagesReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  toUserId   String
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  betId       String?
  messageId   String?
  complaintId String?
  complaint   Complaint? @relation(fields: [complaintId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

/** Point-in-time market state, one per trade (and on create/resolve). */
model MarketSnapshot {
  id        String         @id @default(cuid())
  reason    SnapshotReason
  createdAt DateTime       @default(now())

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String

  points  MarketSnapshotPoint[]

  @@index([eventId, createdAt])
}

/** Per-outcome price/quantity within a single MarketSnapshot. */
model MarketSnapshotPoint {
  id         String @id @default(cuid())
  lmsrQ      Int
  priceCents Int

  snapshot   MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotId String

  outcome   Outcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  outcomeId String

  @@index([snapshotId])
  @@index([outcomeId])
}
